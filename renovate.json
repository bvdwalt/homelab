{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "pinDigests": true,
  "flux": {
    "managerFilePatterns": [
      "/(^|/)k8s/[^/]+/.+\\.yaml$/",
      "/(^|/)k8s/common/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)k8s/[^/]+/.+\\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "allowedVersions": "/^5\\./"
    }
  ]
}
