{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "pinDigests": true,
  "flux": {
    "managerFilePatterns": [
      "/(^|/)k8s/[^/]+/.+\\.yaml$/",
      "/(^|/)k8s/common/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)k8s/[^/]+/.+\\.yaml$/"
    ]
  },
  "hostRules": [
    {
      "matchHost": "docker.gitea.com",
      "hostType": "docker"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "allowedVersions": "/^5\\./"
    },
    {
      "matchUpdateTypes": ["digest"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchPackageNames": ["fluxcd/flux2"],
      "matchUpdateTypes": ["pin", "pinDigest"],
      "enabled": false
    },
    {
      "matchPackageNames": ["aquasecurity/trivy"],
      "matchUpdateTypes": ["pin", "pinDigest"],
      "enabled": false
    }
  ]
}
